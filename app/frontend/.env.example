# ─────────────────────────────────────────────────────────────────────────────
# Stuart Team Real Estate + PropertyDNA — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── n8n Base URL (optional — used as fallback if individual URLs not set)
VITE_N8N_BASE_URL=https://dillabean.app.n8n.cloud/webhook

# ── Funnel Webhook URLs ───────────────────────────────────────────────────────
# Paste your n8n webhook paths for each funnel below.

VITE_PROPERTY_DNA_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/homefax/report
VITE_OPEN_HOUSE_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/stuart-team/open-house
VITE_SELLER_VALUATION_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/stuart-team/seller-valuation
VITE_BUYER_KEYS_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/stuart-team/buyer-access
VITE_OFF_MARKET_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/stuart-team/off-market
VITE_NEWSLETTER_SIGNUP_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/stuart-team/newsletter
VITE_CONTACT_WEBHOOK_URL=https://dillabean.app.n8n.cloud/webhook/stuart-team/contact

# ── External API Keys (server-side only — do not use VITE_ prefix for secrets)
