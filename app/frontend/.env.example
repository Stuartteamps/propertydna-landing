# ─────────────────────────────────────────────────────────────────────────────
# Stuart Team Real Estate + PropertyDNA — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (frontend — anon/publishable key only) ───────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── n8n Webhook URLs ──────────────────────────────────────────────────────────
VITE_N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud/webhook
VITE_PROPERTY_DNA_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/homefax/report
VITE_OPEN_HOUSE_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/open-house
VITE_SELLER_VALUATION_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/seller-valuation
VITE_BUYER_KEYS_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/buyer-access
VITE_OFF_MARKET_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/off-market
VITE_NEWSLETTER_SIGNUP_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/newsletter
VITE_CONTACT_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/contact

# ── External API Keys (server-side — set in Netlify env, NOT here) ───────────
# FBI_CRIME_API_KEY=YOUR_FBI_KEY
# BUILDZOOM_API_KEY=
# SPOTCRIME_API_KEY=
