# ─────────────────────────────────────────────────────────────────────────────
# Stuart Team Real Estate + PropertyDNA — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (frontend — anon/publishable key only) ───────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Mapbox (frontend — REQUIRED for the heat map / property map) ──────────────
# Public token (pk.…). Build-time: if this is missing when you build the WEB
# bundle OR the native app bundle (vite build → cap sync), Mapbox 401s every
# tile and the map renders BLANK. Set it in Netlify env AND in the environment
# used to build the iOS/Android app. In the Mapbox token settings, add
# capacitor://localhost, http://localhost and https://localhost to the allowed
# URLs, otherwise a domain-restricted token 403s inside the native app only.
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# Canonical site origin used to build absolute URLs (e.g. https://thepropertydna.com)
VITE_SITE_URL=https://thepropertydna.com

# ── n8n Webhook URLs ──────────────────────────────────────────────────────────
VITE_N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud/webhook
VITE_PROPERTY_DNA_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/homefax/report
VITE_OPEN_HOUSE_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/open-house
VITE_SELLER_VALUATION_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/seller-valuation
VITE_BUYER_KEYS_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/buyer-access
VITE_OFF_MARKET_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/off-market
VITE_NEWSLETTER_SIGNUP_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/newsletter
VITE_CONTACT_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/stuart-team/contact

# ── External API Keys (server-side — set in Netlify env, NOT here) ───────────
# All v3 enrichment keys are Netlify server-side env vars, not frontend.
# FBI_CRIME_API_KEY=YOUR_FBI_KEY
# BUILDZOOM_API_KEY=
# SPOTCRIME_API_KEY=
# CENSUS_API_KEY=           — free: api.census.gov/data/key_signup.html
# FRED_API_KEY=             — free: fred.stlouisfed.org/docs/api/api_key.html
# HUD_API_KEY=              — free: huduser.gov/portal/dataset/fmr-api.html
# AIRNOW_API_KEY=           — free: docs.airnowapi.org/account/request/
# WALK_SCORE_API_KEY=       — paid: walkscore.com/professional/api.php
# BLS_API_KEY=              — free: data.bls.gov/registrationEngine/
# FIRST_STREET_API_KEY=     — paid: firststreet.org/data-access/
