<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  ═══════════════════════════════════════════════════════════════════
  PLACEHOLDER — Replace all values below with your Firebase config
  ═══════════════════════════════════════════════════════════════════

  STEPS:
  1. Go to https://console.firebase.google.com
  2. Create project (or open existing) → name it "PropertyDNA"
  3. Click "Add app" → iOS → Bundle ID: com.propertydna.app
  4. Download GoogleService-Info.plist → replace this file
  5. Copy REVERSED_CLIENT_ID value → paste into Info.plist
     (replace PASTE_REVERSED_CLIENT_ID_HERE)
  6. In Firebase Console → Authentication → Sign-in method:
     - Enable Google
     - Enable Apple
  7. In Firebase Console → Project Settings → General:
     - Add your Apple Team ID under "App Store ID / Team ID"

  ═══════════════════════════════════════════════════════════════════
-->
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_WITH_CLIENT_ID_FROM_FIREBASE</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>REPLACE_WITH_REVERSED_CLIENT_ID_FROM_FIREBASE</string>
	<key>API_KEY</key>
	<string>REPLACE_WITH_API_KEY_FROM_FIREBASE</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_WITH_GCM_SENDER_ID_FROM_FIREBASE</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.propertydna.app</string>
	<key>PROJECT_ID</key>
	<string>REPLACE_WITH_PROJECT_ID_FROM_FIREBASE</string>
	<key>STORAGE_BUCKET</key>
	<string>REPLACE_WITH_STORAGE_BUCKET_FROM_FIREBASE</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>REPLACE_WITH_GOOGLE_APP_ID_FROM_FIREBASE</string>
</dict>
</plist>
