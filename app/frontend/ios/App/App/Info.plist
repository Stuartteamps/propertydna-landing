<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>

	<!-- App Identity -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>PropertyDNA</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Required for iPhone -->
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Storyboards -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Device capabilities -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>

	<!-- Orientation: portrait + landscape for iPad, portrait-first for iPhone -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Status bar -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>

	<!-- Background modes for push notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>

	<!-- Privacy — Location (for map / parcel geolocation features) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>PropertyDNA uses your location to show nearby property data and heat map parcels.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>PropertyDNA uses your location to show nearby property data and heat map parcels.</string>

	<!-- Privacy — Camera (Vision OCR address scanning + photo attachment) -->
	<key>NSCameraUsageDescription</key>
	<string>PropertyDNA uses the camera to scan property addresses with on-device text recognition so you don't have to type them in.</string>

	<!-- Privacy — Photo Library -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>PropertyDNA may access your photo library to attach images to property reports.</string>

	<!-- App Transport Security — allow our domains -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>thepropertydna.com</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
			</dict>
		</dict>
	</dict>

	<!-- Google Sign In URL scheme (REVERSED_CLIENT_ID from GoogleService-Info.plist) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.thepropertydna.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.thepropertydna.app</string>
				<string>com.googleusercontent.apps.262652433329-1th34cp0n0dtob46n7qr4s2tlnen3l0a</string>
			</array>
		</dict>
	</array>

	<!-- Apple Sign In is handled in entitlements -->
	<!-- Export Compliance: only standard HTTPS, no custom encryption -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Home Screen Quick Actions — long-press the app icon to invoke -->
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.thepropertydna.app.analyze</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Analyze Property</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Generate an intelligence report</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeCompose</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.thepropertydna.app.saved</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Saved Reports</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Offline reports on this device</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeBookmark</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.thepropertydna.app.dashboard</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>My Dashboard</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeContact</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.thepropertydna.app.heatmap</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Market Heat Map</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Live regional market intelligence</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeLocation</string>
		</dict>
	</array>

	<!-- App Intents (Siri / Shortcuts integration) discovered automatically
	     at runtime via PropertyDNAShortcuts in PropertyAppIntents.swift -->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.thepropertydna.app.viewReport</string>
		<string>AnalyzePropertyIntent</string>
		<string>ViewSavedReportsIntent</string>
		<string>OpenDashboardIntent</string>
		<string>ShowMarketHeatmapIntent</string>
	</array>
</dict>
</plist>
