{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": { "EXPO_PUBLIC_API_URL": "http://localhost:8000" }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "EXPO_PUBLIC_API_URL": "https://YOUR-API-HOST" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_API_URL": "https://YOUR-API-HOST" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "8NR9GCA6GQ",
        "appleId": "YOUR_APPLE_ID_EMAIL",
        "ascAppId": "AUTO_CREATED_ON_FIRST_SUBMIT"
      }
    }
  }
}
