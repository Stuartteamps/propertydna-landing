{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["src/api/**/*.ts", "src/lib/**/*.ts", "src/theme/**/*.ts"]
}
