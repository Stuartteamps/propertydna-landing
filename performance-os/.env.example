# ─────────────────────────────────────────────────────────────────────────────
# Performance OS — environment template. Copy to .env. NEVER commit real secrets.
# The full demo runs with these defaults and NO paid credentials.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
ENV=local
DEBUG=true
# Generate: openssl rand -hex 32
SECRET_KEY=dev-insecure-change-me-please-override-in-production-32b+
ACCESS_TOKEN_TTL_MINUTES=10080

# --- Database ---
# SQLite for local demo (default). For Postgres/Supabase:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/postgres
DATABASE_URL=sqlite:///performance_os.db

# --- Feature flags: mock (default) vs real integrations ---
AI_PROVIDER=mock            # mock | openai | anthropic
HEALTH_PROVIDER=mock        # mock | healthkit
CALENDAR_PROVIDER=mock      # mock | google
AUTH_PROVIDER=local         # local | supabase

# --- AI (only needed if AI_PROVIDER != mock) ---
AI_PROVIDER_API_KEY=

# --- Supabase (only needed if using Supabase auth/db/storage) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Calendar OAuth (only needed if CALENDAR_PROVIDER=google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Apple / mobile build (only needed for device builds & TestFlight) ---
APPLE_TEAM_ID=
APPLE_BUNDLE_IDENTIFIER=app.performanceos.mobile

# --- Mobile app: base URL of the API ---
EXPO_PUBLIC_API_URL=http://localhost:8000
