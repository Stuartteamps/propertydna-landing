# ─────────────────────────────────────────────────────────────────────────────
# PropertyDNA Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PER_REPORT=price_...        # $4.99 one-off
STRIPE_PRICE_SUBSCRIPTION=price_...      # $49/mo unlimited
STRIPE_PRICE_ENTERPRISE=price_...        # $149/mo enterprise
STRIPE_PRICE_CONSUMER=price_1TRSwKFtMY7bffn8UmNgYZqw    # $19/mo consumer
STRIPE_PRICE_REALTOR_PRO=price_1TRSwLFtMY7bffn8yq8OJxE4  # $99/mo realtor pro
STRIPE_PRICE_INVESTOR=price_1TRSwLFtMY7bffn88xFInwXF     # $299/mo investor

# Resend (transactional email)
RESEND_API_KEY=re_...

# Internal security
INTERNAL_API_KEY=your_secret_key          # generate: openssl rand -hex 32

# n8n
N8N_WEBHOOK_URL=https://your.n8n.cloud/webhook/...
N8N_API_KEY=your_n8n_api_key

# Google Places (frontend)
VITE_GOOGLE_PLACES_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────────────────────
# v3 Data Pipeline — Free APIs (register at URLs below to get keys)
# All optional — missing keys cause that source to return "unavailable"
# rather than crashing the report.
# ─────────────────────────────────────────────────────────────────────────────

# US Census Bureau — free registration
# Register: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key

# FRED (St. Louis Fed) — mortgage rates, national HPI — free registration
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# HUD Fair Market Rents — free registration
# Register: https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_KEY=your_hud_api_key

# AirNow (EPA air quality) — free registration
# Register: https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=your_airnow_api_key

# Walk Score API — paid tiers, required for walkability scores
# Register: https://www.walkscore.com/professional/api.php
WALK_SCORE_API_KEY=your_walk_score_api_key

# BLS (Bureau of Labor Statistics) — unemployment rates — free registration
# Register: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key

# First Street Foundation — flood/fire/wind/heat risk — contact for pricing
# https://firststreet.org/data-access/
FIRST_STREET_API_KEY=your_first_street_api_key

# BuildZoom — permit history — ~$99/mo
# https://www.buildzoom.com/api
BUILDZOOM_API_KEY=your_buildzoom_api_key

# SpotCrime — local crime incidents — ~$50/mo
# https://spotcrime.com/api
SPOTCRIME_API_KEY=your_spotcrime_api_key

# RentCast — property details, AVM, rental/sale comps, market data, assessment history
RENTCAST_API_KEY=your_rentcast_api_key

# NOAA CDO (weather events) — free registration
# Register: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=your_noaa_token

# Google Maps API — elevation + (already used for Places autocomplete)
# Enable: Elevation API in Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# City open data app token (raises rate limits on Socrata permit APIs — free)
# Register: https://data.cityofchicago.org/profile/app_tokens
CITY_DATA_APP_TOKEN=your_city_data_token

# FBI Crime Data Explorer — state-level violent crime stats — free
# Register: https://cde.ucr.cjis.gov/LATEST/webapp/#/pages/docApi
FBI_CRIME_API_KEY=your_fbi_crime_api_key
