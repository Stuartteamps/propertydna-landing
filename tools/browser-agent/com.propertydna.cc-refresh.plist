<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.propertydna.cc-refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/danstuart/propertydna-landing/tools/browser-agent/refresh-cc-token.js</string>
    </array>

    <!-- Run at 1:00 AM every day (token lasts 24h, issued ~2 AM, refreshed at 1 AM) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>1</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/danstuart/propertydna-landing</string>

    <key>StandardOutPath</key>
    <string>/Users/danstuart/propertydna-landing/tools/browser-agent/refresh.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/danstuart/propertydna-landing/tools/browser-agent/refresh.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <!-- Retry if it fails -->
    <key>ThrottleInterval</key>
    <integer>300</integer>
</dict>
</plist>
